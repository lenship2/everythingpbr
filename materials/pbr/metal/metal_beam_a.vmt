patch
{
	include					"materials/dev/l2_default_pbr.vmt"
	insert
	{
		$basetexture 			"pbr/metal/metal_beam_a_color"
		$bumpmap 				"pbr/metal/metal_beam_normal"
		$mraotexture			"pbr/metal/metal_beam_mrao"
		
		$basetexturetransform	"center 0 0 scale 4 4 rotate 0 translate 0 0"
		
		$surfaceprop			"metal"
		
		$envmaptint				"[0.6 0.6 0.6]"
	}
}