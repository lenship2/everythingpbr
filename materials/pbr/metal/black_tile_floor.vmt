patch
{
	include					"materials/dev/l2_default_pbr.vmt"
	insert
	{
		$basetexture 			"pbr/metal/black_tiles_floor_color"
		$bumpmap 				"pbr/metal/black_tiles_floor_normal"
		$mraotexture			"pbr/metal/black_tiles_floor_mrao"
		$detail 				"detail/detail_blackfloor"
		$detailmask				"pbr/metal/black_tiles_floor_mask"
		
		$detailtransform		"center 0 0 scale 16.8 16.8 rotate 0 translate 0 0"
		
		$mraoscale              "[0.65 1.1 1]"
		$reflectivity			"[0.7 0.7 0.7]"
		$envmaptint				"[0.3 0.3 0.3]"
		$hsv					"[1 1.05 1]"
		
		$detailblendfactor 		"0.6"
		$detailblendmode 		"7"
		
		$surfaceprop			"metalpanel"
	}
}