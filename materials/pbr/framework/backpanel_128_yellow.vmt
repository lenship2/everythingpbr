patch
{
	include					"materials/dev/l2_default_pbr.vmt"
	insert
	{
		$basetexture 			"pbr/framework/backpanel_128_yellow_color"
		$bumpmap 				"pbr/framework/backpanel_128_Parallax"
		$mraotexture			"pbr/framework/backpanel_128_mrao"
		
		$basetexturetransform	"center 0 0 scale 4 4 rotate 0 translate 0 0"
		
		$mraoscale              "[0.75 1 1]"
		$envmaptint				"[0.45 0.45 0.45]"
		
		$parallax 				"1"
		$parallaxcenter 		"0.3"
		$parallaxdepth 			"0.03"
		
		$surfaceprop			"cardboard"
	}
}