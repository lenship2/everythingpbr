patch
{
	include					"materials/dev/l2_default_pbr.vmt"
	insert
	{
		$basetexture 			"pbr/framework/squarebeams_color"
		$bumpmap 				"pbr/framework/squarebeams_Parallax"
		$mraotexture			"pbr/framework/squarebeams_mrao"
		%rectanglemap			"pbr/framework/squarebeams_hotspot"
		
		$basetexturetransform	"center 0 0 scale 4 4 rotate 0 translate 0 0"
		
		$mraoscale              "[0.8 1.2 1]"
		$envmaptint				"[0.7 0.7 0.7]"
		
		$surfaceprop			"metal"
	}
}