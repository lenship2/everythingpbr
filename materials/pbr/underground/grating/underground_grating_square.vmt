PBR
{
$basetexture 			"pbr/underground/grating/underground_grating_square_color"
$bumpmap 				"pbr/underground/grating/underground_grating_square_normal"
$mraotexture			"pbr/underground/grating/underground_grating_square_mrao"

$basetexturetransform	"center 0 0 scale 4 4 rotate 0 translate 0 0"
$bumptransform			"center 0 0 scale 4 4 rotate 0 translate 0 0"
$mraoscale              "[1 1 1]"
$color					"[1 1 1]"

$parallax 				"0"

$alphatest				"1"
$envmap					"env_cubemap"
$envmaptint				"[0.3 0.3 0.3]"
$envmaplightscale		"0.6"
$surfaceprop			metalgrate
"%compilepassbullets"	"1"
"%nopaint"				"1"
"%noportal"				"1"
}