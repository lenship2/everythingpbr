patch
{
	include					"materials/dev/l2_default_pbr.vmt"
	insert
	{
		$basetexture 			"pbr\concrete\concrete_bricks_01_Color"
		$bumpmap 				"pbr\concrete\concrete_bricks_01_Normal"
		$mraotexture			"pbr\concrete\concrete_bricks_01_MRAO"
		
		$basetexturetransform	"center 0 0 scale 4 4 rotate 0 translate 0 0"
		
		$envmaptint				"[0.1 0.1 0.1]"
		
		$surfaceprop			"concrete"
		
		"%noportal"				"0"
	}
}