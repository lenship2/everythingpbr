patch
{
	include					"materials/dev/l2_default_pbr.vmt"
	insert
	{
		$basetexture 			"pbr/glass/portal_glass_02_Color"
		$bumpmap 				"pbr/glass/portal_glass_02_Normal"
		$mraotexture			"pbr/glass/portal_glass_01_MRAO"
		
		$basetexturetransform	"center 0 0 scale 2 2 rotate 0 translate 0 0"
		
		$translucent			"1"
		
		$envmaptint				"[1 1 1]"
		
		$surfaceprop			"glass"
	}
}