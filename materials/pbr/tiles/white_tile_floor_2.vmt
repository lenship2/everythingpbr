patch
{
	include					"materials/dev/l2_default_pbr.vmt"
	insert
	{
		$basetexture 			"pbr/tiles/white_tile_floor_2_color"
		$bumpmap 				"pbr/tiles/white_tile_floor_1_normal"
		$mraotexture			"pbr/tiles/white_tile_floor_1_mrao"
		
		$surfaceprop			"concrete"
		
		$basetexturetransform	"center 0 0 scale 4 4 rotate 0 translate 0 0"
		
		$reflectivity 			"[0.8 0.8 0.8]" 
		
		"%noportal"				"0"
	}
}