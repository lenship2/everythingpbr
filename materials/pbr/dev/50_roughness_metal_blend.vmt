PBR
{
$basetexture 			"pbr/dev/dev_pbr_50_color"
$basetexture2			"pbr/dev/dev_pbr_metal_color"
$mraotexture			"pbr/dev/dev_pbr_50_mrao"
$mraotexture			"pbr/dev/dev_pbr_metal_mrao"

$basetexturetransform	"center 0 0 scale 2 2 rotate 0 translate 0 0"
$basetexturetransform2 	"center 0 0 scale 2 2 rotate 0 translate 0 0"

$parallax 				"0"

$surfaceprop			"default"

$envmap					"env_cubemap"
$envmaplightscale		"0.6"

$envmap2				"env_cubemap"
$envmaplightscale2		"0.6"

%noportal				"1"
}