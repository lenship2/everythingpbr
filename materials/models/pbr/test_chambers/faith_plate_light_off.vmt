Refract
{
$basetexture 		"models/pbr/test_chambers/faithplate_light_color"
$normalmap 			"models/pbr/test_chambers/faithplate_light_normal"

$envmap				"cubemaps/cubemap_glass_01"

$model 				"1"

$refractamount 		"0.025"
$bluramount 		"1"

$localrefract 		"1"
$localrefractdepth 	"0.05"

$scale 				"[1 1]"

//rgb plate color
$refracttint		"[0.15 0.15 0.15]"
}