PBR
{
	$basetexture 			"models\pbr\underground\fizzler_old_Color"
	$bumpmap				"models\pbr\underground\fizzler_old_Normal"
	$mraotexture			"models\pbr\underground\fizzler_old_MRAO"
	$emissiontexture		"models\pbr\underground\fizzler_old_SelfIllum"

	$mraoscale              "[0.9 1 1]"
	$envmaptint				"[0.3 0.3 0.3]"
	
	$model					"1"

	$parallax 				"0"
	$parallaxdither        	"0"
	$parallaxscale          "2"

	$envmaplightscale		"0.6"
	$blendtintbymraoalpha	"1"

	$envmap					"env_cubemap"

	"%noportal"				"1"
	
	Proxies
	{
		Sine
		{
			sineperiod 3
			sinemin 0.1
			sinemax 0.4
			resultVar "$emissionscale[0]"
		}
	}
}