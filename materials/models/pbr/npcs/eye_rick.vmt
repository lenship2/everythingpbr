PBR
{
	$basetexture 			"models\pbr\npcs\adventure_Color"
	$bumpmap				"models\pbr\npcs\adventure_Normal"
	$mraotexture			"models\pbr\npcs\adventure_MRAO"
	$emissiontexture		"models\pbr\npcs\adventure_selfillum"

	$mraoscale              "[0.9 1 1]"
	$envmaptint				"[0.1 0.1 0.1]"
	
	$model					"1"

	$parallax 				"0"
	$parallaxdither        	"0"
	$parallaxscale          "2"

	$envmaplightscale		"0.6"
	$blendtintbymraoalpha	"1"

	$envmap					"env_cubemap"

	"%noportal"				"1"
	
	proxies
	{
		AnimatedTexture
		{
			animatedTextureVar			"$emissiontexture"
			animatedtextureframenumvar	"$emissionframe"
			animatedtextureframerate	"10"
		}
		LightedMouth
		{
			resultvar					"$emissionscale"
		}
	}
}