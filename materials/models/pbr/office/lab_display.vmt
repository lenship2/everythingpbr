PBR
{
$basetexture 			"models\pbr\office\lab_display_Color"
$mraotexture			"models\pbr\office\lab_display_MRAO"
$emissiontexture		"models\pbr\office\lab_display_Selfillum"

$model					"1"

$mraoscale              "[0.9 1 1]"

$parallax 				"0"

$envmap					"env_cubemap"
$envmaptint				"[0.3 0.3 0.3]"

Proxies
{
	TextureScroll
	{
		textureScrollVar		$emissiontransform
		textureScrollRate 		"1"
		textureScrollAngle 		"0"
	}
}
}